# Copy this file to .env for local development. Do NOT commit .env.

# Required for every deployment target.
GENIE_SPACE_ID=01f0XXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Local dev: authenticate with a personal access token (PAT).
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Azure (App Service / Container Apps): authenticate with a service principal
# instead of a PAT. Set these as app settings / container env vars — not in .env.
# DATABRICKS_CLIENT_ID=<sp-application-id>
# DATABRICKS_CLIENT_SECRET=<sp-oauth-secret>
